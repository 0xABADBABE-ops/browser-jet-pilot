# MCP Browser Server - Configuration

# Browser connection (CDP)
# Connect to existing Chromium via Chrome DevTools Protocol
CDP_URL=http://localhost:9222

# Or launch a new browser
# LAUNCH=true
# BROWSER_WIDTH=1280
# BROWSER_HEIGHT=720

# Set to true to accept self-signed/invalid TLS certificates
# (useful in Docker or behind intercepting proxies)
# BROWSER_IGNORE_HTTPS_ERRORS=false

# Disable Chromium sandbox (required in Docker; dangerous on host)
# BROWSER_NO_SANDBOX=false

# MCP Server
# Use --port flag for HTTP transport, otherwise uses stdio
# PORT=3100
# HOST=localhost
